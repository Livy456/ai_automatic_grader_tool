# Root-level pointers. Copy real env files on servers under AGT_platform/ (never commit secrets).

# Backend loads env in order: AGT_platform/backend/.env.local then AGT_platform/backend/.env
# (.env overrides). `.env.local` is gitignored and holds local defaults; see that file template
# in docs or copy from a teammate.

# --- Web / app EC2 (.env.production next to docker-compose.web.prod.yaml) ---
# SPA origin for OAuth redirects after Microsoft/Google (no trailing slash). Must match
# where you open the UI: Docker frontend service → http://localhost:5173 ; host npm run dev
# → http://localhost:5174 (see frontend/vite.config.ts). Wrong port → ERR_CONNECTION_REFUSED.
FRONTEND_BASE_URL=
# Browser-reachable Flask API for OAuth redirect_uri (local Docker from host: :5000).
# Set when the SPA is on another port so Microsoft/Google callbacks match app registration.
PUBLIC_API_URL=
# Host-only: if compose maps backend to :5000, run local Flask on another port, e.g. FLASK_PORT=5001
FLASK_PORT=
CORS_ORIGINS=
DATABASE_URL=
REDIS_URL=

# --- S3 / MinIO (submissions, rubrics, answer keys, ingest) ---
# Do NOT mix: S3_ENDPOINT=http://minio:9000 with S3_BUCKET=<AWS-only bucket name>.
# MinIO only has buckets you create on MinIO (default dev: ai-grader). AWS bucket names on MinIO
# cause NoSuchBucket. See AGT_platform/docs/s3_bucket_and_presigned_uploads_setup.md
#
# Presigned PUT URLs must use a host the *browser* can open. Docker defaults use
# S3_ENDPOINT=http://minio:9000 (API/worker only). Backend auto-sets presign to
# http://127.0.0.1:9000 when S3_ENDPOINT is exactly that; override with S3_PRESIGN_ENDPOINT
# if MinIO is published elsewhere (e.g. tunnel or different port).
S3_PRESIGN_ENDPOINT=
# Local Docker (defaults also set in AGT_platform/docker-compose.yaml for backend + worker):
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
S3_SECURE=
S3_ADDRESSING_STYLE=
# Optional: JSON grading reports land here (defaults to S3_BUCKET). Celery worker must match.
S3_GRADING_REPORTS_BUCKET=

# AWS S3 (same bucket for API + Celery workers; use IAM role on EC2 when possible):
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=   # omit if using instance profile / IRSA
S3_SECRET_KEY=
## leave S3_ENDPOINT unset or empty
S3_SECURE=
## omit S3_ADDRESSING_STYLE or use virtual-hosted default
# Optional tuning (large files):
MAX_UPLOAD_MB=
S3_INLINE_UPLOAD_MAX_BYTES=
S3_UPLOAD_SPOOL_MAX_MEMORY_BYTES=
# Full bucket checklist: copy S3_BUCKET_SETUP.md from repo template (file is gitignored).

# --- OAuth (optional; omit or leave empty to disable that provider) ---
# Generic OIDC / campus SSO
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_REDIRECT_URI=
# Microsoft (Azure AD / Entra)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional authority segment: empty → "common" (multi-tenant). Set to Directory (tenant)
# GUID for one org, or "organizations" / "consumers". Must match app registration "Supported
# account types". ID token `iss` is always validated with a Microsoft-safe check in code.
MICROSOFT_TENANT_ID=
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production: redirect URIs must match what you register
# --- Split deploy (GitHub Actions) ---
DEPLOY_STACK=          # repo secret; omit or monolith for legacy single host
GPU_SERVER_HOST=       # optional secret; GPU job runs only when set with DEPLOY_STACK=split

# --- GPU EC2 ---
# Copy AGT_platform/env.production.gpu.example → .env.production.gpu

# --- Frontend (AGT_platform/frontend/.env.development.local or Compose .env for Vite container) ---
# Backend URL for fetch() — always the API, not the Vite port. Local Docker: http://localhost:5000
VITE_API_BASE=
# Optional override for full-page OAuth only; defaults to VITE_API_BASE then http://localhost:5000.
# Must match PUBLIC_API_URL / Entra redirect URI host (e.g. https://api.example.com).
VITE_OAUTH_API_ORIGIN=

# --- Direct S3 uploads + web tier hardening (see docs/production_architecture_redesign.md) ---
ALLOW_FLASK_MULTIPART_UPLOAD=   # false on web prod; true for local docker-compose dev
WEB_MAX_BODY_MB=
UPLOADS_S3_PREFIX=              # default assignments/by-id
S3_PRESIGN_PUT_EXPIRES=
AWS_REGION=                     # alias for S3_REGION when using AWS docs
DEPLOYMENT_TIER=                # web | gpu

# OAuth session cookie: false for http://localhost API; true when API is HTTPS-only (production).
SESSION_COOKIE_SECURE=

# JWT: short-lived access (Bearer, SPA memory) + long-lived refresh (HttpOnly cookie).
# If JWT_ACCESS_EXPIRATION_SECONDS is unset, JWT_EXPIRATION_SECONDS controls access lifetime (default 15m).
JWT_ACCESS_EXPIRATION_SECONDS=
JWT_EXPIRATION_SECONDS=
JWT_REFRESH_EXPIRATION_SECONDS=
REFRESH_TOKEN_COOKIE_NAME=
# Omit to mirror SESSION_COOKIE_SECURE; set true/false to override for the refresh cookie only.
REFRESH_COOKIE_SECURE=
# lax | strict | none — use none + HTTPS when SPA and API are different sites (requires Secure).
REFRESH_COOKIE_SAMESITE=

# --- OpenAI escalation (workers; key never in browser) ---
OPENAI_MODEL=
ESCALATE_TO_OPENAI=

# --- Multi-LLM grading (workers) ---
# Two additional models grade alongside the primary Ollama model. The final score is the
# average of all successful grades. Format: "ollama:<model>" or "openai:<model>".
# Leave empty for single-model grading (original behaviour).
GRADING_MODEL_2=
GRADING_MODEL_3=

# --- Semantic entropy sampling (legacy pipeline only; not staged) ---
# off (default) = one grade per model, existing behaviour. on + k>1 = k stochastic samples
# per model; final score = mean over all valid samples; entropy from fingerprint clusters.
GRADING_ENTROPY_MODE=
# Samples per grading model (1–16). 1 disables sampling even if ENTROPY_MODE=on.
GRADING_SAMPLES_PER_MODEL=
# Temperature for stochastic grading samples (Ollama options / OpenAI API). Default 0.3.
GRADING_SAMPLE_TEMPERATURE=
# fingerprint (default MVP) | openai (reserved; uses fingerprint until implemented).
GRADING_ENTROPY_EMBEDDINGS=
# Flag needs_review if valid_samples/attempted_samples falls below this ratio (0–1).
GRADING_ENTROPY_MIN_SUCCESS_RATE=
# If natural-log semantic_entropy exceeds this, append high_semantic_entropy + needs_review.
GRADING_ENTROPY_REVIEW_NATURAL_H=

# --- Five-stage grading pipeline (workers) ---
# legacy = existing monolithic grade() + optional multi-LLM average (default).
# staged = normalize → evidence extract → per-criterion score → consistency → aggregate.
# chunk_entropy = RAG-style chunks → per-unit k samples × each model → semantic entropy per unit + aggregate.
GRADING_PIPELINE_MODE=
# Human-review routing in staged mode (instructors may tune per deployment).
REVIEW_CONFIDENCE_THRESHOLD=
REVIEW_NEAR_BOUNDARY_POINTS=
# Cap JSON size passed into each staged LLM call (characters).
STAGED_PROMPT_MAX_CHARS=
# true = each rubric criterion scored by primary + GRADING_MODEL_2 + GRADING_MODEL_3; scores averaged.
# (Evidence extraction still uses the primary model only, to limit cost.)
STAGED_MULTI_LLM=

# --- Celery worker (GPU host) ---
CELERY_WORKER_CONCURRENCY=
CELERY_WORKER_PREFETCH=
# Ollama reachable from this process. Laptop (no GPU tier): same machine as `ollama serve`.
# Example: http://127.0.0.1:11434 — must NOT point at a GPU host you cannot reach.
OLLAMA_BASE_URL=
# Optional override when workers run in Docker / split deploy (defaults to OLLAMA_BASE_URL).
INTERNAL_OLLAMA_URL=
# Primary chat model (ollama pull … must succeed). Small local examples:
# OLLAMA_MODEL=llama3.2:1b
# Extra models: use GRADING_MODEL_2 / GRADING_MODEL_3 in the Multi-LLM block above.
# Example triple of small models (verify tags with `ollama list` after pulling):
# OLLAMA_MODEL=llama3.2:1b
# GRADING_MODEL_2=ollama:gemma3:4b
# GRADING_MODEL_3=ollama:deepseek-r1:1.5b
# GRADING_PIPELINE_MODE=staged
# STAGED_MULTI_LLM=true
# Read timeout per /api/chat call (seconds). Use 90–180 on CPU-only laptops; 300+ on GPU.
OLLAMA_CHAT_TIMEOUT_SEC=
# Ask Ollama /api/chat for JSON-shaped replies (default on). Set "false" if the model errors.
OLLAMA_CHAT_JSON_FORMAT=
# Embedding model for RAG / local tests (pull with: ollama pull nomic-embed-text)
OLLAMA_EMBEDDINGS_MODEL=
# Max characters of submission text sent to embedding APIs
RAG_EMBED_MAX_CHARS=
# auto | openai_first | ollama_first | openai_only | ollama_only — auto tries OpenAI first when OPENAI_API_KEY is set (skips broken Ollama /api/embed on many installs).
RAG_EMBED_ORDER=
# on | off | auto — set on to call OpenAI (OPENAI_API_KEY) to reshape .ipynb into compact qa_units; off/auto use deterministic chunks only.
NOTEBOOK_OPENAI_DIGEST=
# Skip slow tests that call a real Ollama (unittest discover): SKIP_LOCAL_LLM_TESTS=true
SKIP_LOCAL_LLM_TESTS=
# Seconds for test_grading_pipeline_local_files chat smoke only (default 60 if unset; not OLLAMA_CHAT_TIMEOUT_SEC).
LOCAL_LLM_SMOKE_TIMEOUT_SEC=
# --- tests/test_grading_pipeline_local_files.py (multimodal path) ---
# Defaults when unset: MAX_ASSIGNMENTS=1, GRADING_SAMPLES=1, MAX_GRADING_UNITS=8 (fast pytest).
# First N assignment basenames (sorted). 0 or all = grade every basename under assignments_to_grade/.
MULTIMODAL_LOCAL_TEST_MAX_ASSIGNMENTS=
# Override k samples per model for that test only (1–16). from_config = use GRADING_SAMPLES_PER_MODEL from .env.
MULTIMODAL_LOCAL_TEST_GRADING_SAMPLES=
# Cap multimodal grading units per assignment. 0 or all = no cap (full submission).
MULTIMODAL_LOCAL_TEST_MAX_GRADING_UNITS=
# --- Multimodal pipeline RAG (app.grading.multimodal.rag_embeddings) ---
# on (default) = per-unit embedding via same stack as app.grading.rag_embeddings (OpenAI/Ollama/hash).
MULTIMODAL_RAG_EMBED_UNITS=
# Optional: skip rubric-type anchor embeddings (faster CI); assignment rubric type uses ipynb/text fallbacks only.
MULTIMODAL_SKIP_RUBRIC_ANCHOR_EMBED=
# Override ``custom_rubric/`` output directory for multimodal assignment rubric JSON.
MULTIMODAL_CUSTOM_RUBRIC_OUTPUT_DIR=
# on = use a small Ollama model to JSON-segment Q/A pairs with keys (fallback: heuristic chunker).
MULTIMODAL_OLLAMA_QA_SEGMENT=
# Preferred user-facing alias for the same LLM segmentation step (any backend below).
MULTIMODAL_ASSIGNMENT_PARSING=
MULTIMODAL_LLM_QA_SEGMENT=
# When ANTHROPIC_API_KEY is set: auto (default) = use Claude for assignment parsing; off = use Ollama/OpenAI/HF only.
MULTIMODAL_ANTHROPIC_ASSIGNMENT_PARSING=
ANTHROPIC_API_KEY=
# Default claude-opus-4-7; override with your workspace “Opus” id if different.
MULTIMODAL_ANTHROPIC_PARSING_MODEL=
MULTIMODAL_ANTHROPIC_PARSING_MAX_TOKENS=
# Model for QA segmentation only (default llama3.2:1b). Primary OLLAMA_MODEL is unchanged for grading.
MULTIMODAL_QA_SEGMENT_MODEL=
