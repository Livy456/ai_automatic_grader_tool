# GPU EC2 — copy to .env.production.gpu next to docker-compose.gpu.prod.yaml.
# Redis/Postgres often live on the web tier: use VPC private IPs / RDS endpoints.

DATABASE_URL=
# Celery broker on web EC2 (security group: allow 6379 from this GPU instance only)
REDIS_URL=

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
AWS_REGION=
S3_SECURE=
S3_ADDRESSING_STYLE=
UPLOADS_S3_PREFIX=

OLLAMA_BASE_URL=http://ollama:11434
INTERNAL_OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ESCALATE_TO_OPENAI=false

CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH=1
DEPLOYMENT_TIER=gpu

SECRET_KEY=
